flowchart TB
    subgraph ROW1["ReadingCorpusTools: paper and location state"]
        direction LR
        SCOPE["user_id + scope.paper_ids<br/>Java Corpus API cannot widen this scope"]:::control
        DISCOVER["search_paper_candidates<br/>or find_papers_by_identity"]:::tool
        PAPERS["authorized_paper_ids<br/>returned paper IDs"]:::state
        LOCATE["find_reading_locations<br/>Java/Qdrant candidates + Current Model validation"]:::tool
        LOCATIONS["disclosed_location_refs<br/>returned location_ref values"]:::state

        SCOPE --> DISCOVER
        DISCOVER -->|unique or returned papers| PAPERS
        PAPERS -->|required| LOCATE
        LOCATE -->|preview + location_ref| LOCATIONS
    end

    subgraph ROW2["ReadingCorpusTools + submit_research_answer"]
        direction RL
        READ["read_locations<br/>requires disclosed_location_refs<br/>exact retained span"]:::tool
        EVIDENCE["observations_by_evidence_id<br/>Evidence ID + provenance"]:::evidence
        SUBMIT["submit_research_answer<br/>outcome + markdown + fields"]:::tool
        VALIDATE["answer_validation_error<br/>evaluate_evidence_coverage"]:::control
        ACCEPTED["accepted draft<br/>tools_to_final_output ends Runner"]:::answer
        REFERENCES["ChatHandler referenceMappings<br/>persisted with the conversation"]:::source

        READ -->|create| EVIDENCE
        EVIDENCE -->|known IDs only| SUBMIT
        SUBMIT --> VALIDATE
        VALIDATE -->|accepted| ACCEPTED
        ACCEPTED --> REFERENCES
    end

    LOCATIONS ~~~ READ

