# 复制为项目根目录 `.env` 后再填写真实值。
# 应用启动时会自动读取该文件，适用于 IDE 直接跑 main 和 `mvn spring-boot:run`。

# Spring profile，通常本地使用 dev
SPRING_PROFILES_ACTIVE=dev
APP_TIMEZONE=Asia/Shanghai

# 服务监听端口
SERVER_PORT=8081

# MySQL
PAPERLOOM_DB_SCHEMA=paperloom
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/paperloom?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=

# Redis
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# Kafka，topic 会在应用启动时自动创建，无需再手工执行 kafka-topics.sh
SPRING_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
SPRING_KAFKA_TOPIC_PARTITIONS=1
SPRING_KAFKA_TOPIC_REPLICATION_FACTOR=1

# MinIO，对象存储用于文件上传与解析链路
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=uploads

# PDF parser. MinerU is installed and run separately from the Docker data services.
PAPER_PARSING_PROVIDER=mineru
PAPER_PARSING_MINERU_BASE_URL=http://127.0.0.1:8000

# Qdrant stores the rebuildable Current Reading Model candidate index.
# Generate a non-empty key before starting docs/docker-compose.yaml; production also fails closed without it.
QDRANT_BASE_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=paperloom_reading_elements_dense_sparse_v1

# JWT_SECRET_KEY 必须是 Base64 字符串，可用 `openssl rand -base64 32` 生成
JWT_SECRET_KEY=

# 首次启动创建管理员时临时打开，创建成功后应改回 false
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-strong-password
ADMIN_BOOTSTRAP_PRIMARY_ORG=default
ADMIN_BOOTSTRAP_ORG_TAGS=default,admin
PAPERLOOM_SMOKE_PASSWORD=

# Optional Docker resource overrides. Defaults use `paperloom-*` names.
PAPERLOOM_MYSQL_CONTAINER=paperloom-mysql
PAPERLOOM_REDIS_CONTAINER=paperloom-redis
PAPERLOOM_MINIO_CONTAINER=paperloom-minio
PAPERLOOM_KAFKA_CONTAINER=paperloom-kafka
PAPERLOOM_QDRANT_CONTAINER=paperloom-qdrant
PAPERLOOM_MYSQL_VOLUME=paperloom-mysql-data
PAPERLOOM_REDIS_VOLUME=paperloom-redis-data
PAPERLOOM_MINIO_VOLUME=paperloom-minio-data
PAPERLOOM_KAFKA_VOLUME=paperloom-kafka-data
PAPERLOOM_QDRANT_VOLUME=paperloom-qdrant-data

# Optional host-port overrides for docs/docker-compose.yaml.
MYSQL_HOST_PORT=3306
REDIS_HOST_PORT=6379
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
QDRANT_HTTP_HOST_PORT=6333
QDRANT_GRPC_HOST_PORT=6334

# 注册模式：OPEN / INVITE_ONLY / CLOSED
APP_AUTH_REGISTRATION_MODE=INVITE_ONLY
APP_AUTH_INVITE_REQUIRED=true

# 前端来源白名单，多个域名用逗号分隔
SECURITY_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*

# Research Harness LLM，由部署环境管理
MINIMAX_API_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M3
RESEARCH_HARNESS_PYTHON=.venv-harness/bin/python
EVAL_DUMP_DIR=
RESEARCH_HARNESS_BASE_URL=http://127.0.0.1:8091
RESEARCH_HARNESS_INTERNAL_TOKEN=
JAVA_CORPUS_BASE_URL=http://127.0.0.1:8081
JAVA_CORPUS_MAX_RESPONSE_BYTES=8388608

# Java legacy LLM defaults and product Embedding provider
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_API_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_MODEL=text-embedding-v4
EMBEDDING_API_KEY=

# 日志等级，排障时可临时改为 DEBUG
LOG_LEVEL_APP=INFO

# 前端部署
DEPLOY_SERVER_HOST=
DEPLOY_SERVER_USER=root
DEPLOY_SERVER_KEY=/absolute/path/to/paperloom-deploy.pem
DEPLOY_TARGET_DIR=/home/www/paperloom-frontend
DEPLOY_HEALTHCHECK_URL=
DEPLOY_HEALTHCHECK_TIMEOUT=15

# 微信支付相关配置
WX_PAY_ENABLE=false
WX_PAY_APP_ID=
WX_PAY_MERCHANT_ID=
WX_PAY_PRIVATE_KEY=
WX_PAY_MERCHANT_SERIAL_NUMBER=
WX_PAY_API_V3_KEY=
WX_PAY_NOTIFY_URL=
WX_PAY_REFUND_NOTIFY_URL=
