# Copy this to .runtime/product-launch.env for local launch runs.
# .runtime/ is ignored; never commit the copied file with real secrets.

# Required for ProductLaunchRuntimePreflightCli.
DEEPSEEK_API_KEY=
EMBEDDING_API_KEY=

# Optional OpenAI-compatible provider overrides.
# Keep these explicit so launch evidence records the provider/runtime you actually used.
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_API_MODEL=deepseek-chat
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_MODEL=text-embedding-v4

# Optional frontend runtime target. The preflight requires the served SPA shell at this URL.
PAPERLOOM_FRONTEND_BASE_URL=http://127.0.0.1:9527

# Local launch wrappers set this to true at command time; the application default remains false.
PAPERLOOM_REACT_READING_PHASE1_ENABLED=true

# Local MinerU sidecar default used by scripts/paperloom-start-mineru.sh.
PAPER_PARSING_MINERU_BASE_URL=http://127.0.0.1:8000
